---
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import Breadcrumb from "@/components/Breadcrumb.astro";
import Layout from "@/layouts/Layout.astro";
import { SITE } from "@/config";
---

<Layout title={`Book a Call | ${SITE.title}`} description="Schedule time with Will Burks.">
  <Header />
  <Breadcrumb />
  <main id="main-content" class="app-layout">
    <section class="mb-28 max-w-app">
      <h1 class="text-2xl tracking-wider sm:text-3xl mb-2">Book a Call</h1>
      <p class="mb-8 opacity-70">Pick a time that works for you.</p>
      <div
        class="calendly-inline-widget"
        data-url="https://calendly.com/william-burks"
        style="min-width:320px;height:700px;"
      >
      </div>
    </section>
  </main>
  <Footer />
</Layout>

<script is:inline src="https://assets.calendly.com/assets/external/widget.js" async></script>
